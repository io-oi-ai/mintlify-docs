{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Plain",
  "description": "AI 时代的 Office. The Office for the AI era.",
  "colors": {
    "primary": "#C8102E",
    "light": "#E63951",
    "dark": "#A20A24"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Welcome",
            "pages": [
              "index",
              "quickstart",
              "concepts/why-text-html"
            ]
          },
          {
            "group": "Three forms",
            "pages": [
              "forms/deck",
              "forms/doc",
              "forms/sheet"
            ]
          },
          {
            "group": "Workflow",
            "pages": [
              "workflow/inspect-mode",
              "workflow/cross-doc-refs",
              "workflow/share-and-export",
              "workflow/present-mode"
            ]
          },
          {
            "group": "Brand templates",
            "pages": [
              "brand/upload",
              "brand/batch-generate"
            ]
          },
          {
            "group": "AI agents",
            "pages": [
              "ai/mcp",
              "ai/cli-from-cursor",
              "ai/cli-from-claude-code"
            ]
          }
        ]
      },
      {
        "tab": "CLI",
        "groups": [
          {
            "group": "Command line",
            "pages": [
              "cli/install",
              "cli/commands",
              "cli/byok"
            ]
          }
        ]
      },
      {
        "tab": "API",
        "groups": [
          {
            "group": "Reference",
            "pages": [
              "api/overview",
              "api/auth",
              "api/agent",
              "api/render",
              "api/export"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Showcase",
          "href": "https://inplain.app/showcase",
          "icon": "sparkles"
        },
        {
          "anchor": "Pricing",
          "href": "https://inplain.app/pricing",
          "icon": "credit-card"
        },
        {
          "anchor": "Changelog",
          "href": "https://inplain.app/changelog",
          "icon": "newspaper"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/io-oi-ai/Plain",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "appearance": {
    "default": "light"
  },
  "navbar": {
    "links": [
      {
        "label": "Workspace",
        "href": "https://inplain.app/app"
      },
      {
        "label": "Support",
        "href": "mailto:hi@inplain.app"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Try Plain",
      "href": "https://inplain.app"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "seo": {
    "metatags": {
      "og:image": "https://inplain.app/opengraph-image",
      "twitter:site": "@_zephyr_dev"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/_zephyr_dev",
      "github": "https://github.com/io-oi-ai/Plain"
    },
    "links": [
      {
        "header": "Plain",
        "items": [
          { "label": "Workspace", "href": "https://inplain.app/app" },
          { "label": "Showcase", "href": "https://inplain.app/showcase" },
          { "label": "Pricing", "href": "https://inplain.app/pricing" },
          { "label": "Changelog", "href": "https://inplain.app/changelog" }
        ]
      },
      {
        "header": "Resources",
        "items": [
          { "label": "Manifesto", "href": "https://inplain.app/manifesto" },
          { "label": "Blog", "href": "https://inplain.app/blog" },
          { "label": "About", "href": "https://inplain.app/about" }
        ]
      }
    ]
  }
}
